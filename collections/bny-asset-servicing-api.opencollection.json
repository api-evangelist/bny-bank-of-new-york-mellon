{
  "opencollection": "1.0.0",
  "info": {
    "name": "BNY Asset Servicing API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Asset Servicing",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Asset Servicing Status",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://apigateway.bny.com/v1/status"
          },
          "docs": "Returns the current status of the BNY Asset Servicing API surface."
        }
      ]
    }
  ],
  "bundled": true
}